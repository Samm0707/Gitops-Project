# STAGE 1: Build the application using Maven and JDK 17
FROM maven:3.9-eclipse-temurin-17 AS builder
LABEL stage=builder
WORKDIR /app
COPY .mvn/ .mvn
COPY mvnw pom.xml ./
RUN chmod +x mvnw
RUN ./mvnw dependency:go-offline -B
COPY src ./src
RUN ./mvnw package -DskipTests

# Download the OpenTelemetry Java auto-instrumentation agent here, in the
# builder stage (which has curl) — keeps the final runtime image free of
# extra tools, same least-privilege reasoning as the non-root user below.
RUN curl -sSL -o /opt/opentelemetry-javaagent.jar \
    https://github.com/open-telemetry/opentelemetry-java-instrumentation/releases/latest/download/opentelemetry-javaagent.jar

# STAGE 2: Create the runtime image using JRE 17
FROM eclipse-temurin:17-jre-focal
WORKDIR /app

RUN addgroup --system spring && adduser --system --ingroup spring spring \
    && mkdir -p /app/uploads \
    && chown -R spring:spring /app

EXPOSE 8081

COPY --from=builder /app/target/*.jar app.jar
COPY --from=builder /opt/opentelemetry-javaagent.jar otel-agent.jar
RUN chown spring:spring /app/app.jar /app/otel-agent.jar

USER spring:spring

# The -javaagent flag auto-instruments Spring MVC, Tomcat, and JDBC calls
# with zero code changes — traces are generated by bytecode instrumentation
# at runtime, configured entirely through OTEL_* env vars (set in the Rollout).
ENTRYPOINT ["java", "-javaagent:/app/otel-agent.jar", "-jar", "app.jar"]